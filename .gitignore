yarn-error.log*
.pnpm-debug.log*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright
playwright-report
test-results
.playwright-home
/.playwright-cli
/output/playwright

# agent state
/.agent/*
!/.agent/PLANS.md
!/.agent/done/
!/.agent/done/**
/.agent/done/**/*.md
/.agent/local
/.agent/*.local.md
/.agent/future-plans
/.openclaw
/.clawdbot
/.moltbot
/agent-canvas
/worktrees
/.claude

# local issue tracker
/.beads

# bv (beads viewer) local config and caches
.bv/

# Local HTTPS development certificates
.certs/
.understand-anything/

# === Smart Vault Additions ===

# Agent session logs — local only
agents/*/sessions/
agents/*/memory/

# Auth credentials — local only
agents/*/auth-profiles.json

# Agent KB symlinks — local only
agents/*/KB

# Large media files — too big for GitHub (keep on local/F drive)
output/course-assets/*.mp3
output/course-assets/*.mp4
output/course-assets/*.pptx
output/course-assets/*.png

# Generated tool projects
output/free-ai-tools/
