# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Environment variables — NEVER commit
.env
.env*
!.env.example
*.env

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.jks
*.keystore
.netrc
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

